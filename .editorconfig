# EditorConfig helps maintain consistent coding styles across editors and IDEs
# https://editorconfig.org

root = true

# ------------------------------------------------
# Default settings for all files
# ------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ------------------------------------------------
# Python
# ------------------------------------------------
[*.py]
indent_size = 4
max_line_length = 100

# ------------------------------------------------
# YAML
# ------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ------------------------------------------------
# JSON
# ------------------------------------------------
[*.json]
indent_size = 2

# ------------------------------------------------
# Shell scripts
# ------------------------------------------------
[*.{sh,bash}]
indent_size = 2

# ------------------------------------------------
# PowerShell
# ------------------------------------------------
[*.ps1]
indent_size = 4

# ------------------------------------------------
# Markdown
# ------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ------------------------------------------------
# Docker
# ------------------------------------------------
[Dockerfile*]
indent_size = 4

# ------------------------------------------------
# Makefile
# ------------------------------------------------
[Makefile]
indent_style = tab