# Harmonia - Modular AI & Data Platform - Environment Configuration Template
# ================================================
#
# Copy this file to .env and customize for your environment.
# This file defines all configurable values for Harmonia - Modular AI & Data Platform.
#
# Usage:
#   Copy-Item config\env\.env.example config\env\.env
#   notepad config\env\.env
#   docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml --profile infra --profile tools up -d

# ================================================
# GENERAL SETTINGS
# ================================================

# Timezone for all services
TZ=UTC

# ================================================
# COMPOSE / PROJECT NAMING
# ================================================

# Project name (used for container naming)
# Default: compose (from directory name)
# COMPOSE_PROJECT_NAME=ai-platform




# ================================================
# NETWORKING / DOMAINS
# ================================================

# Main platform domain
AI_DOMAIN=ai.localhost

# Service hostnames (accessible via Traefik)
OPENWEBUI_HOST=openwebui.localhost
ADMINER_HOST=db.localhost
MLFLOW_HOST=mlflow.localhost
#MINIO_CONSOLE_HOST=minio.localhost

# Optional future services
API_HOST=api.localhost
UI_HOST=ui.localhost

# ================================================
# POSTGRESQL - Relational Database
# ================================================

# Database credentials
POSTGRES_USER=ai
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=ai

# Note: PostgreSQL runs on port 5432 (internal only)
# To access locally, add compose/docker-compose.dev-core.yml

# ================================================
# MONGODB - Document Store
# ================================================

# MongoDB root credentials
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-password

# Note: MongoDB runs on port 27017 (internal only)
# To access locally, add compose/docker-compose.dev-core.yml

# ================================================
# MINIO - S3-Compatible Object Storage
# ================================================

# MinIO root credentials
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password

# Buckets to create on startup (comma-separated)
MINIO_BUCKETS=mlflow,artifacts,docs

# MinIO console hostname
MINIO_CONSOLE_HOST=minio.localhost

# Note: MinIO runs on port 9000 (API) and 9001 (console)
# Console accessible via Traefik at http://minio.localhost

# ================================================
# SQL SERVER - Optional Relational Database
# ================================================

# SQL Server SA (System Administrator) password
# IMPORTANT: Must be at least 8 characters, include uppercase, lowercase, digit, and special char
MSSQL_SA_PASSWORD=ChangeMe!Random123

# Note: SQL Server is optional and disabled by default
# To enable, add compose/docker-compose.sqlserver.yml and --profile sqlserver
# Runs on port 1433 (internal only)

# ================================================
# QDRANT - Vector Database
# ================================================

# Qdrant hostname
QDRANT_HOST=qdrant.localhost

# Note: Qdrant runs on port 6333 (API) and 6334 (gRPC)
# Accessible via Traefik at http://qdrant.localhost/dashboard

# ================================================
# OLLAMA - LLM Runtime
# ================================================


# Backend options:
# OLLAMA_BACKEND=rocm  # AMD ROCm on Linux/WSL2
# OLLAMA_BACKEND=cuda  # NVIDIA GPU
# OLLAMA_BACKEND=cpu   # CPU-only fallback
# Since we are using Native Windows Ollama, we point to the host

# Ollama connection URL
# For Windows with native Ollama: http://host.docker.internal:11434
# For Docker-based Ollama: http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama keep-alive timeout
OLLAMA_KEEP_ALIVE=5m

# Optional: Override GPU detection for AMD GPUs
# Uncomment if using older/unofficial AMD GPUs with ROCm
# HSA_OVERRIDE_GFX_VERSION=10.3.0

# ================================================
# MONITORING - Prometheus & Grafana
# ================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Prometheus hostname
PROMETHEUS_HOST=prometheus.localhost

# Note: Monitoring services are optional
# To enable, add -f docker-compose.monitoring.yml to your compose command
# Grafana: http://grafana.localhost or http://127.0.0.1:3001
# Prometheus: http://prometheus.localhost or http://127.0.0.1:9090
# cAdvisor: http://cadvisor.localhost or http://127.0.0.1:8082
# Node Exporter: http://127.0.0.1:9100/metrics

# ================================================
# ORCHESTRATION - Prefect & Dagster
# ================================================

# Prefect Server hostname
# Prefect is a Python-first workflow orchestration platform
# Use for: ML pipelines, LLM workflows, Python-native data pipelines
PREFECT_HOST=prefect.localhost

# Prefect API URL (internal)
PREFECT_API_URL=http://prefect-server:4200/api

# Database connection for Prefect (Uses the core Postgres)
# Replace 'your_password' with your actual POSTGRES_PASSWORD
# PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://username:your_password@postgres:5432/prefect


# Dagster Web UI hostname
# Dagster is a data orchestration platform focused on assets and lineage
# Use for: Data pipelines, asset-oriented workflows, data lineage tracking
DAGSTER_HOST=dagster.localhost

# Dagster database configuration (uses PostgreSQL)
DAGSTER_POSTGRES_DB=dagster

# Note: Orchestration services are optional
# To enable, add -f docker-compose.orchestration.yml to your compose command
# Prefect: http://prefect.localhost
# Dagster: http://dagster.localhost

# ================================================
# OPTIONAL: LOCAL PATHS (Windows Example)
# ================================================

# These are optional and only needed if you want to mount local directories
# Uncomment and customize for your environment

OLLAMA_MODELS=D:\ai-models\ollama
AI_PLATFORM_ROOT=D:\ai-platform
AI_PLATFORM_STATE=D:\ai-platform\volumes
AI_PLATFORM_LOGS=D:\ai-platform\logs
AI_PLATFORM_TMP=D:\ai-platform\tmp


# ================================================
# IMPORTANT NOTES
# ================================================

# 1. SECURITY
#    - Change all "change-me" passwords before production use
#    - Use strong passwords (min 12 characters, mixed case, numbers, symbols)
#    - Never commit this file to version control
#    - Add .env to .gitignore

# 2. WINDOWS / DOCKER DESKTOP
#    - Use host.docker.internal to reach Windows host services
#    - Ensure Docker Desktop has WSL2 enabled
#    - Ensure Docker Desktop has "Expose daemon on tcp://localhost:2375" disabled

# 3. NETWORKING
#    - Services are accessible via Traefik at *.localhost hostnames
#    - Add entries to Windows hosts file if needed:
#      C:\Windows\System32\drivers\etc\hosts
#    - Or use Docker Desktop's built-in DNS resolution

# 4. PROFILES
#    - Use --profile infra to start core services (always needed)
#    - Use --profile tools to start OpenWebUI, MLflow, Adminer
#    - Use --profile monitoring to start Prometheus, Grafana, cAdvisor
#    - Use --profile orchestration to start Prefect and Dagster
#    - Use --profile sqlserver only with the SQL Server overlay

# 5. ENVIRONMENT VARIABLES
#    - All values use ${VAR_NAME:-default} pattern
#    - If not set in .env, defaults are used
#    - Customize only what you need

# ================================================
# STARTUP EXAMPLES
# ================================================

# Core infrastructure only:
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml --profile infra up -d

# Core + tools (recommended):
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml --profile infra --profile tools up -d

# Core + tools + monitoring:
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml -f .\compose\docker-compose.monitoring.yml --profile infra --profile tools --profile monitoring up -d

# With Ollama (AMD GPU):
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml -f .\compose\docker-compose.runtime.ollama.base.yml -f .\compose\docker-compose.runtime.ollama.rocm.yml --profile infra --profile tools --profile runtime up -d

# With Ollama (NVIDIA GPU):
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml -f .\compose\docker-compose.runtime.ollama.base.yml -f .\compose\docker-compose.runtime.ollama.cuda.yml --profile infra --profile tools --profile runtime up -d

# With Ollama (CPU only):
# docker compose --env-file .\config\env\.env -f .\compose\docker-compose.yml -f .\compose\docker-compose.tools.yml -f .\compose\docker-compose.runtime.ollama.base.yml -f .\compose\docker-compose.runtime.ollama.cpu.yml --profile infra --profile tools --profile runtime up -d

# With local developer port exposure for core data services:
# Add -f .\compose\docker-compose.dev-core.yml to a stack command above
