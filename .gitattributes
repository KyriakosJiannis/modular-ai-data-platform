# ------------------------------------------------
# Normalize line endings for all text files
# ------------------------------------------------
* text=auto

# ------------------------------------------------
# Force LF for scripts and config files
# ------------------------------------------------
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile* text eol=lf

# ------------------------------------------------
# Binary files (no diff / no modification)
# ------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
